# ========================================
# AI Interview System — Root .gitignore
# ========================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.Python
*.so

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- Environment / secrets ---
.env
.env.local
.env.*.local

# --- Node / Frontend ---
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Uploads & runtime data ---
backend/uploads/photos/*
backend/uploads/recordings/*
backend/uploads/resumes/*
!backend/uploads/photos/.gitkeep
!backend/uploads/recordings/.gitkeep
!backend/uploads/resumes/.gitkeep

# --- Database ---
*.db
*.sqlite3

# --- Misc ---
*.log
*.bak
*.tmp
